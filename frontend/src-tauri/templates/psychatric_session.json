{
  "name": "Psychiatrische Sitzung",
  "description": "KI-gestützte psychiatrische Vorlage basierend auf SOAP, mit klinischen Metadaten und KI-Zusammenfassung.",
  "sections": [
    {
      "title": "Sitzungs-Metadaten",
      "instruction": "Datum, Start/Endzeit, Ort/Modalität (Telemedizin/Präsenz), Patient-ID, Behandler",
      "format": "string"
    },
    {
      "title": "KI-Sitzungszusammenfassung",
      "instruction": "Vom LLM generierter, unstrukturierter Absatz, der die Stimmung des Patienten, den Tonfall und die wichtigsten besprochenen Themen aus dem Transkript zusammenfasst.",
      "format": "paragraph"
    },
    {
      "title": "Subjektiv (S)",
      "instruction": "Angaben des Patienten, Symptome, Stimmungsbericht",
      "format": "list"
    },
    {
      "title": "Objektiv (O)",
      "instruction": "Beobachtungen des Behandlers: Affekt, Aussehen, Sprechgeschwindigkeit, Vitalfunktionen usw.",
      "format": "list"
    },
    {
      "title": "Beurteilung (A)",
      "instruction": "Klinische Synthese, Schlussfolgerungen zur Symptomverbesserung/verschlechterung",
      "format": "paragraph"
    },
    {
      "title": "Plan (P)",
      "instruction": "Interventionen, diagnostische Tests, Therapieanpassungen, Zuweisungen",
      "format": "list"
    },
    {
      "title": "Medikamente",
      "instruction": "Änderungen bei aktuellen Rezepten",
      "format": "list",
      "item_format": "| **Medikament** | **Dosis** | **Häufigkeit** | **Status/Änderung** |\n| --- | --- | --- | --- |"
    },
    {
      "title": "Diagnosen (DSM/ICD)",
      "instruction": "Aktive Diagnosen",
      "format": "list",
      "item_format": "| **ICD/DSM-Code** | **Beschreibung** | **Status** |\n| --- | --- | --- |"
    },
    {
      "title": "Sicherheit & Risikomanagement",
      "instruction": "Suiziert/Hormizid-Risiko, Sicherheitsverträge oder Auslöser",
      "format": "paragraph"
    },
    {
      "title": "Nächster Termin",
      "instruction": "Wann der Patient zurückkehrt und wer plant",
      "format": "string"
    },
    {
      "title": "Audit-Trail",
      "instruction": "Referenz zum Roh-Transkript und Erstellungsdatum/Uhrzeit",
      "format": "string"
    }
  ]
}
